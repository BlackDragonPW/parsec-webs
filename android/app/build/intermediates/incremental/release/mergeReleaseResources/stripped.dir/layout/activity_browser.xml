<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ── WebView container (behind chrome) ──────────────────────────── -->
    <FrameLayout
        android:id="@+id/webview_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Suggestion overlay ─────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/suggestions_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@color/surface"
        android:elevation="8dp"
        android:visibility="gone" />

    <!-- ── Bottom sheet (panels, not the toolbar) ─────────────────────── -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/surface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:visibility="gone" />

    <!-- ── Browser chrome: progress + toolbar ─────────────────────────── -->
    <LinearLayout
        android:id="@+id/toolbar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/toolbar_bg"
        android:elevation="4dp"
        android:orientation="vertical">

        <!-- Load progress bar (above toolbar) -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone"
            android:progressTint="@color/accent" />

        <!-- URL bar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <!-- Back -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:src="@drawable/ic_back"
                android:tint="@color/icon_tint" />

            <!-- Forward -->
            <ImageButton
                android:id="@+id/btn_forward"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Forward"
                android:src="@drawable/ic_forward"
                android:tint="@color/icon_tint" />

            <!-- Lock icon -->
            <ImageView
                android:id="@+id/lock_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_secure"
                android:contentDescription="Connection security" />

            <!-- URL / search bar -->
            <EditText
                android:id="@+id/url_bar"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/url_bar_bg"
                android:hint="Search or enter URL"
                android:imeOptions="actionGo|flagNoExtractUi"
                android:inputType="textUri"
                android:maxLines="1"
                android:paddingHorizontal="10dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <!-- Reload / Stop -->
            <ImageButton
                android:id="@+id/btn_reload"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Reload"
                android:src="@drawable/ic_reload"
                android:tint="@color/icon_tint" />

            <!-- Tab count -->
            <Button
                android:id="@+id/btn_tabs"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/tab_count_bg"
                android:text="1"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- New tab -->
            <ImageButton
                android:id="@+id/btn_new_tab"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="New tab"
                android:src="@drawable/ic_add"
                android:tint="@color/icon_tint" />

            <!-- Menu -->
            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                android:src="@drawable/ic_menu"
                android:tint="@color/icon_tint" />

        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
