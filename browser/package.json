{
  "name": "parsec-web",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --port 1421",
    "build": "tsc && vite build",
    "start": "cargo run --manifest-path src-tauri/Cargo.toml",
    "start:release": "cargo run --manifest-path src-tauri/Cargo.toml --release",
    "webkit:build": "cd webkit-build && ./build.sh",
    "webkit:patch": "cd webkit-build && ./build.sh --patches-only",
    "webkit:fast": "cd webkit-build && ./build.sh --fast"
  },
  "dependencies": {
    "@types/react-reconciler": "^0.33.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}
