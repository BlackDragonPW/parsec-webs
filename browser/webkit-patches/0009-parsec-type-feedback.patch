diff --git a/Source/JavaScriptCore/dfg/DFGByteCodeParser.cpp b/Source/JavaScriptCore/dfg/DFGByteCodeParser.cpp
--- a/Source/JavaScriptCore/dfg/DFGByteCodeParser.cpp
+++ b/Source/JavaScriptCore/dfg/DFGByteCodeParser.cpp
@@ -1,5 +1,6 @@
 #include "config.h"
 #include "DFGByteCodeParser.h"
+#include "ParsecTypeProfile.h"
 
 namespace JSC { namespace DFG {
 
@@ -310,6 +311,45 @@ SpeculatedType ByteCodeParser::getPredictionWithoutOSRExit(unsigned bytecodeOffs
 {
+#if ENABLE(PARSEC_TYPE_FEEDBACK)
+    // ── Parsec: prefer our richer histogram over ValueProfile's single slot ──
+    //
+    // JSC's default getPrediction reads the last-seen type from ValueProfile.
+    // Our ParsecTypeProfile tracks a 4-slot histogram with counts, giving
+    // much higher confidence on the dominant type.
+    //
+    // We only override when:
+    //   1. A ParsecTypeProfile exists for this site
+    //   2. Confidence exceeds 97% (fewer than 3% of observations are outliers)
+    //   3. The dominant type is more specific than what ValueProfile reports
+    //
+    // This is exactly how Turbofan decides whether to speculate — it has
+    // a "stability" threshold below which it won't speculate on a type.
+
+    if (auto* parsecProfile = m_codeBlock->parsecTypeProfileForOffset(bytecodeOffset)) {
+        float confidence = parsecProfile->confidence();
+        PTC dominant = parsecProfile->dominantType();
+
+        // Only use Parsec profile if we have high confidence
+        if (confidence >= 0.97f && parsecProfile->totalObservations() >= 50) {
+            SpeculatedType parsecSpec = ptcToSpeculatedType(dominant);
+
+            // Further refine: if our profile says Int32 with 99%+ confidence,
+            // tell FTL it's SpecInt32Only — the most aggressive specialization.
+            // ValueProfile often reports SpecBytecodeNumber which is less specific.
+            if (dominant == PTC::Int32 && confidence >= 0.99f)
+                parsecSpec = SpecInt32Only;
+            else if (dominant == PTC::Double && confidence >= 0.99f)
+                parsecSpec = SpecDoubleReal;
+            else if (dominant == PTC::String && confidence >= 0.98f)
+                parsecSpec = SpecString;
+            else if (dominant == PTC::Object && confidence >= 0.97f)
+                parsecSpec = SpecFinalObject;
+
+            // Merge with ValueProfile result — take the intersection
+            // (more specific = better speculation, but don't disagree with evidence)
+            SpeculatedType vpSpec = getPredictionFromValueProfile(bytecodeOffset);
+            if (parsecSpec != SpecNone && (vpSpec == SpecNone || parsecSpec == (parsecSpec & vpSpec)))
+                return parsecSpec;
+
+            // If they agree directionally, use the more specific one
+            if ((parsecSpec & vpSpec) != SpecNone)
+                return parsecSpec & vpSpec;
+        }
+    }
+#endif // ENABLE(PARSEC_TYPE_FEEDBACK)
+
     // Default: use ValueProfile
     return getPredictionFromValueProfile(bytecodeOffset);
 }

diff --git a/Source/JavaScriptCore/dfg/DFGAbstractInterpreterInlines.h b/Source/JavaScriptCore/dfg/DFGAbstractInterpreterInlines.h
--- a/Source/JavaScriptCore/dfg/DFGAbstractInterpreterInlines.h
+++ b/Source/JavaScriptCore/dfg/DFGAbstractInterpreterInlines.h
@@ -1,5 +1,6 @@
 #include "DFGAbstractInterpreter.h"
+#include "ParsecTypeProfile.h"
 
 namespace JSC { namespace DFG {
 
@@ -440,6 +441,38 @@ bool AbstractInterpreter<AbstractStateType>::executeEffects(unsigned clobberLimi
         // ── Parsec: use binary profile for arithmetic type narrowing ──────
         // When DFG abstract interpretation encounters an ArithAdd/Sub/Mul,
         // we can narrow the result type using ParsecBinaryProfile data.
         // This tells DFG that (Int32 + Int32) → Int32 with high confidence,
         // enabling it to emit unboxed arithmetic in the JIT code it generates.
+#if ENABLE(PARSEC_TYPE_FEEDBACK)
+        if (node->op() == ArithAdd || node->op() == ArithSub || node->op() == ArithMul) {
+            unsigned bco = node->origin.semantic.bytecodeIndex().offset();
+            if (auto* bp = codeBlock()->parsecBinaryProfileForOffset(bco)) {
+                if (bp->isAlwaysIntInt()) {
+                    // Both operands are always Int32 — result is Int32
+                    // Tell DFG: speculate Int32 on both inputs
+                    node->child1().setUseKindUnchecked(Int32Use);
+                    node->child2().setUseKindUnchecked(Int32Use);
+                    forNode(node).setType(m_graph, SpecInt32Only);
+                    break;
+                }
+                if (bp->isAlwaysNumericNumeric()) {
+                    // Both are numeric — result is Double
+                    node->child1().setUseKindUnchecked(DoubleRepUse);
+                    node->child2().setUseKindUnchecked(DoubleRepUse);
+                    forNode(node).setType(m_graph, SpecDouble);
+                    break;
+                }
+            }
+            // Array access: use array profile to determine element kind
+            if (node->op() == GetByVal) {
+                unsigned bco2 = node->origin.semantic.bytecodeIndex().offset();
+                if (auto* ap = codeBlock()->parsecArrayProfileForOffset(bco2)) {
+                    if (ap->isPackedSmi())
+                        forNode(node).setType(m_graph, SpecInt32Only);
+                    else if (ap->isPackedDouble())
+                        forNode(node).setType(m_graph, SpecDouble);
+                }
+            }
+        }
+#endif // ENABLE(PARSEC_TYPE_FEEDBACK)
         break;
     }

diff --git a/Source/JavaScriptCore/ftl/FTLLowerDFGToB3.cpp b/Source/JavaScriptCore/ftl/FTLLowerDFGToB3.cpp
--- a/Source/JavaScriptCore/ftl/FTLLowerDFGToB3.cpp
+++ b/Source/JavaScriptCore/ftl/FTLLowerDFGToB3.cpp
@@ -1,5 +1,6 @@
 #include "config.h"
 #include "FTLLowerDFGToB3.h"
+#include "ParsecTypeProfile.h"
 
 namespace JSC { namespace FTL {
 
@@ -1200,6 +1201,42 @@ private:
+
+    // ── Parsec: enhanced call specialization via ParsecCallProfile ────
+    // FTL normally emits a polymorphic call dispatch for op_call.
+    // If ParsecCallProfile shows the call site is monomorphic (one callee
+    // seen 97%+ of the time), we emit a direct call with a guard check
+    // and an OSR exit for the rare mismatch case.
+    //
+    // This is exactly how Turbofan handles megamorphic call sites that
+    // are "effectively monomorphic" — the IC has seen many callees but
+    // one dominates in practice.
+
+    void compileCallWithParsecProfile(Node* node)
+    {
+#if ENABLE(PARSEC_TYPE_FEEDBACK)
+        unsigned bco = node->origin.semantic.bytecodeIndex().offset();
+        auto* cp = m_graph.m_codeBlock->parsecCallProfileForOffset(bco);
+        if (cp && cp->isMonomorphic()) {
+            uintptr_t expectedCallee = cp->dominantCallee();
+            if (expectedCallee) {
+                // Emit: load callee ptr, compare to expected, branch to OSR if mismatch
+                LValue actualCallee = lowCell(node->child1());
+                LValue expectedPtr  = m_out.constIntPtr(expectedCallee);
+                LValue isExpected   = m_out.equal(actualCallee, expectedPtr);
+
+                LBasicBlock directCallBlock = m_out.newBlock();
+                LBasicBlock slowCallBlock   = m_out.newBlock();
+
+                m_out.branch(isExpected, usually(directCallBlock), rarely(slowCallBlock));
+
+                // Direct call path — compiler knows the callee, can inline
+                m_out.appendTo(directCallBlock, slowCallBlock);
+                // Emit direct call (inlining handled by DFG inliner upstream)
+                compileDirectCall(node, reinterpret_cast<JSObject*>(expectedCallee));
+
+                // Slow path — OSR exit to DFG which handles polymorphic dispatch
+                m_out.appendTo(slowCallBlock, m_out.newBlock());
+                addExitCode(node->origin, ExitKind::BadCache);
+                return;
+            }
+        }
+#endif
