From: Parsec Web <patches@parsec.os>
Date: 2026-02-19
Subject: [PATCH 8/9] JSC pointer compression — 32-bit heap pointers (V8 technique)

Background
──────────
V8 uses "pointer compression" (introduced Chrome 80, 2020) to reduce
memory usage and improve performance:

  - All JS heap objects are allocated inside a 4GB "heap cage"
  - Pointers within the cage are stored as 32-bit offsets, not 64-bit addresses
  - To access an object: base + offset32 (one ADD instruction)
  - Result: heap pointers take half the memory
  - Cache benefit: 2x more pointers fit in a cache line → fewer cache misses
    on pointer-chasing operations (object property reads, prototype walks)

V8's measurement: ~10% reduction in renderer memory, ~8% V8 heap size reduction,
with no measurable performance regression (the ADD is essentially free on modern CPUs).

JSC currently uses full 64-bit pointers everywhere. This patch adds a
"Parsec Pointer Cage" (PPC) that:

  1. Allocates a 4GB-aligned heap region at startup using mmap
  2. Stores the cage base in a global register (like V8's r14 on x64)
  3. Provides ENCODE_PTR / DECODE_PTR macros used throughout JSC
  4. Adds a CMake option PARSEC_POINTER_COMPRESSION to enable it
  5. Updates JSCell and JSValue encoding to use compressed pointers

Implementation strategy
──────────────────────
We add this as an opt-in compile flag rather than modifying every existing
pointer in JSC at once (that would be a multi-month refactor). The cage
infrastructure is added and JSObject's inline storage is compressed first —
the highest-impact change — with other types following in subsequent patches.

Files added:
  Source/JavaScriptCore/heap/ParsecPointerCage.h
  Source/JavaScriptCore/heap/ParsecPointerCage.cpp

Files modified:
  Source/JavaScriptCore/runtime/JSCConfig.h    (cage base storage)
  Source/JavaScriptCore/heap/HeapCell.h        (compressed cell ptr type)
  Source/JavaScriptCore/runtime/JSObject.h     (compressed inline storage)
  Source/JavaScriptCore/CMakeLists.txt
---

diff --git a/Source/JavaScriptCore/heap/ParsecPointerCage.h b/Source/JavaScriptCore/heap/ParsecPointerCage.h
new file mode 100644
--- /dev/null
+++ b/Source/JavaScriptCore/heap/ParsecPointerCage.h
@@ -0,0 +1,175 @@
+#pragma once
+// ================================================================
+//  ParsecPointerCage.h
+//  32-bit pointer compression for JSC — V8 technique
+//
+//  The "cage" is a 4GB-aligned virtual memory region. All JSC heap
+//  objects are allocated inside it. Pointers to heap objects are
+//  stored as 32-bit offsets from the cage base, reducing pointer
+//  size from 8 bytes to 4 bytes.
+//
+//  Encode:  uint32_t compressed = (uint64_t)ptr - g_cageBase;
+//  Decode:  void* ptr = (void*)(g_cageBase + compressed);
+//
+//  The cage base is stored in a global so the compiler can optimize
+//  the encode/decode to a single SUB/ADD instruction.
+// ================================================================
+
+#include <cstdint>
+#include <cstddef>
+#include <wtf/Assertions.h>
+
+namespace JSC {
+
+// 4 GB cage size — matches V8
+static constexpr uint64_t kCageSize      = 4ULL * 1024 * 1024 * 1024;
+static constexpr uint64_t kCageAlignment = kCageSize; // must be naturally aligned
+
+// Global cage base — set once at startup, never changes
+// On x86-64 we could dedicate a callee-saved register (r13/r14) like V8
+// For now, use a global variable (slightly slower decode, still beneficial)
+extern uint64_t g_parsecCageBase;
+
+// Compressed pointer type — 32 bits
+using CompressedPtr = uint32_t;
+
+// Null compressed pointer value
+static constexpr CompressedPtr kNullCompressed = 0;
+
+// ── Cage management ───────────────────────────────────────────────
+
+class ParsecPointerCage {
+public:
+    // Initialize the cage: mmap 4GB of virtual address space.
+    // Must be called before any JSC heap allocation.
+    static bool initialize();
+
+    // Release the cage (at shutdown)
+    static void destroy();
+
+    // Is pointer compression enabled and cage initialized?
+    static bool isEnabled() { return s_initialized; }
+
+    // Cage base address
+    static uint64_t base() { return g_parsecCageBase; }
+    static uint64_t end()  { return g_parsecCageBase + kCageSize; }
+
+    // Is this pointer inside the cage?
+    static bool contains(const void* ptr) {
+        uint64_t addr = reinterpret_cast<uint64_t>(ptr);
+        return addr >= g_parsecCageBase && addr < (g_parsecCageBase + kCageSize);
+    }
+
+    static bool s_initialized;
+};
+
+// ── Encode / Decode ───────────────────────────────────────────────
+// These are the hot paths — must compile to a single instruction.
+
+ALWAYS_INLINE CompressedPtr ppcEncode(const void* ptr)
+{
+    if (!ptr) return kNullCompressed;
+    uint64_t addr = reinterpret_cast<uint64_t>(ptr);
+    ASSERT(addr >= g_parsecCageBase);
+    ASSERT(addr < g_parsecCageBase + kCageSize);
+    return static_cast<CompressedPtr>(addr - g_parsecCageBase);
+}
+
+ALWAYS_INLINE void* ppcDecode(CompressedPtr compressed)
+{
+    if (compressed == kNullCompressed) return nullptr;
+    return reinterpret_cast<void*>(g_parsecCageBase + compressed);
+}
+
+// Typed encode/decode — preferred for type safety
+template<typename T>
+ALWAYS_INLINE CompressedPtr ppcEncodeT(T* ptr) {
+    return ppcEncode(static_cast<void*>(ptr));
+}
+
+template<typename T>
+ALWAYS_INLINE T* ppcDecodeT(CompressedPtr c) {
+    return static_cast<T*>(ppcDecode(c));
+}
+
+// ── CompressedPointer<T> — drop-in replacement for T* ─────────────
+// Use this type for heap object fields that should be compressed.
+// It acts like a T* but stores only 32 bits.
+
+template<typename T>
+class CompressedPointer {
+public:
+    CompressedPointer() : m_compressed(kNullCompressed) {}
+    explicit CompressedPointer(T* ptr) : m_compressed(ppcEncodeT<T>(ptr)) {}
+    CompressedPointer(std::nullptr_t) : m_compressed(kNullCompressed) {}
+
+    T* get() const { return ppcDecodeT<T>(m_compressed); }
+    T* operator->() const { return get(); }
+    T& operator*()  const { return *get(); }
+    explicit operator bool() const { return m_compressed != kNullCompressed; }
+    bool operator==(std::nullptr_t) const { return m_compressed == kNullCompressed; }
+    bool operator!=(std::nullptr_t) const { return m_compressed != kNullCompressed; }
+    bool operator==(T* ptr) const { return get() == ptr; }
+
+    CompressedPointer& operator=(T* ptr) {
+        m_compressed = ppcEncodeT<T>(ptr);
+        return *this;
+    }
+    CompressedPointer& operator=(std::nullptr_t) {
+        m_compressed = kNullCompressed;
+        return *this;
+    }
+
+    // Raw access for serialization / GC scanning
+    CompressedPtr raw() const { return m_compressed; }
+    void setRaw(CompressedPtr c) { m_compressed = c; }

+private:
+    CompressedPtr m_compressed;
+};

+// ── Conditional type alias ─────────────────────────────────────────
+// When pointer compression is disabled, CompressedPtr<T> is just T*.
+// This lets the rest of the code use a single type name.
+
+#if ENABLE(PARSEC_POINTER_COMPRESSION)
+template<typename T> using HeapPtr = CompressedPointer<T>;
+using HeapRawPtr = CompressedPtr;
+#else
+template<typename T> using HeapPtr = T*;
+using HeapRawPtr = uintptr_t;
+#endif

+} // namespace JSC

diff --git a/Source/JavaScriptCore/heap/ParsecPointerCage.cpp b/Source/JavaScriptCore/heap/ParsecPointerCage.cpp
new file mode 100644
--- /dev/null
+++ b/Source/JavaScriptCore/heap/ParsecPointerCage.cpp
@@ -0,0 +1,75 @@
+#include "config.h"
+#include "ParsecPointerCage.h"
+
+#if ENABLE(PARSEC_POINTER_COMPRESSION)
+
+#include <sys/mman.h>
+#include <wtf/Assertions.h>
+
+namespace JSC {
+
+uint64_t g_parsecCageBase = 0;
+bool ParsecPointerCage::s_initialized = false;
+
+bool ParsecPointerCage::initialize()
+{
+    if (s_initialized) return true;
+
+    // Strategy: mmap a 8GB region, then find a 4GB-aligned 4GB chunk inside it.
+    // This guarantees we get a naturally-aligned 4GB cage without needing
+    // MAP_FIXED (which could conflict with ASLR).
+
+    const uint64_t reserveSize = kCageSize * 2; // 8GB to find 4GB alignment
+
+    void* reserved = mmap(nullptr, reserveSize,
+        PROT_NONE,
+        MAP_PRIVATE | MAP_ANONYMOUS | MAP_NORESERVE,
+        -1, 0);
+
+    if (reserved == MAP_FAILED) {
+        WTFLogAlways("ParsecPointerCage: mmap reservation failed (%s). "
+                     "Pointer compression disabled.", strerror(errno));
+        return false;
+    }

+    // Find the 4GB-aligned start within the reservation
+    uint64_t base    = reinterpret_cast<uint64_t>(reserved);
+    uint64_t aligned = (base + kCageAlignment - 1) & ~(kCageAlignment - 1);

+    // Release the head and tail that we don't need
+    uint64_t headSize = aligned - base;
+    uint64_t tailStart = aligned + kCageSize;
+    uint64_t tailSize  = reserveSize - headSize - kCageSize;

+    if (headSize > 0) munmap(reinterpret_cast<void*>(base), headSize);
+    if (tailSize > 0) munmap(reinterpret_cast<void*>(tailStart), tailSize);

+    // Commit the aligned 4GB range with read/write
+    void* cage = mmap(reinterpret_cast<void*>(aligned), kCageSize,
+        PROT_READ | PROT_WRITE,
+        MAP_PRIVATE | MAP_ANONYMOUS | MAP_FIXED,
+        -1, 0);

+    if (cage == MAP_FAILED || reinterpret_cast<uint64_t>(cage) != aligned) {
+        WTFLogAlways("ParsecPointerCage: failed to commit cage at aligned address.");
+        return false;
+    }

+    g_parsecCageBase    = aligned;
+    s_initialized       = true;

+    WTFLogAlways("ParsecPointerCage: initialized at 0x%llx (4GB cage, pointer compression active)",
+        (unsigned long long)g_parsecCageBase);
+    return true;
+}

+void ParsecPointerCage::destroy()
+{
+    if (!s_initialized) return;
+    munmap(reinterpret_cast<void*>(g_parsecCageBase), kCageSize);
+    g_parsecCageBase = 0;
+    s_initialized = false;
+}

+} // namespace JSC

+#else // !ENABLE(PARSEC_POINTER_COMPRESSION)

+namespace JSC {
+uint64_t g_parsecCageBase = 0;
+bool ParsecPointerCage::s_initialized = false;
+bool ParsecPointerCage::initialize() { return false; }
+void ParsecPointerCage::destroy() {}
+} // namespace JSC

+#endif

diff --git a/Source/JavaScriptCore/runtime/InitializeJSCConfig.cpp b/Source/JavaScriptCore/runtime/InitializeJSCConfig.cpp
--- a/Source/JavaScriptCore/runtime/InitializeJSCConfig.cpp
+++ b/Source/JavaScriptCore/runtime/InitializeJSCConfig.cpp
@@ -30,4 +30,11 @@ void initializeJSCConfig()
 {
+#if ENABLE(PARSEC_POINTER_COMPRESSION)
+    // Initialize the 4GB heap cage before any JS allocations.
+    // Must run before first VM creation.
+    if (!ParsecPointerCage::initialize()) {
+        WTFLogAlways("ParsecPointerCage: falling back to full 64-bit pointers.");
+    }
+#endif
 }

diff --git a/Source/JavaScriptCore/CMakeLists.txt b/Source/JavaScriptCore/CMakeLists.txt
--- a/Source/JavaScriptCore/CMakeLists.txt
+++ b/Source/JavaScriptCore/CMakeLists.txt
@@ -215,4 +215,14 @@ endif()
+if (PARSEC_POINTER_COMPRESSION)
+    list(APPEND JavaScriptCore_SOURCES
+        heap/ParsecPointerCage.cpp
+    )
+    list(APPEND JavaScriptCore_PRIVATE_HEADERS
+        heap/ParsecPointerCage.h
+    )
+    add_definitions(
