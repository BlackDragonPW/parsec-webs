diff --git a/Source/JavaScriptCore/bytecode/CodeBlock.h b/Source/JavaScriptCore/bytecode/CodeBlock.h
--- a/Source/JavaScriptCore/bytecode/CodeBlock.h
+++ b/Source/JavaScriptCore/bytecode/CodeBlock.h
@@ -1,5 +1,6 @@
 #pragma once
+#include "ParsecTypeProfile.h"
 
 namespace JSC {
 
@@ -380,6 +381,60 @@ public:
+
+#if ENABLE(PARSEC_TYPE_FEEDBACK)
+    // ── Parsec profile storage ────────────────────────────────────────
+    //
+    // Four profile arrays indexed by bytecode offset.
+    // Allocated lazily on first profiling hit to avoid overhead for cold code.
+    // All arrays are the same size as the bytecode instruction count.
+
+    // Type profile: records what JSValue types appear at a result/operand site
+    ParsecTypeProfile* parsecTypeProfileForOffset(unsigned bcOffset) const
+    {
+        if (!m_parsecTypeProfiles || bcOffset >= m_parsecProfileSize)
+            return nullptr;
+        return &m_parsecTypeProfiles[bcOffset];
+    }

+    // Binary profile: records (lhsType, rhsType) pairs for arithmetic ops
+    ParsecBinaryProfile* parsecBinaryProfileForOffset(unsigned bcOffset) const
+    {
+        if (!m_parsecBinaryProfiles || bcOffset >= m_parsecProfileSize)
+            return nullptr;
+        return &m_parsecBinaryProfiles[bcOffset];
+    }

+    // Array profile: records element kind for array accesses
+    ParsecArrayProfile* parsecArrayProfileForOffset(unsigned bcOffset) const
+    {
+        if (!m_parsecArrayProfiles || bcOffset >= m_parsecProfileSize)
+            return nullptr;
+        return &m_parsecArrayProfiles[bcOffset];
+    }

+    // Call profile: records callees seen at call sites
+    ParsecCallProfile* parsecCallProfileForOffset(unsigned bcOffset) const
+    {
+        if (!m_parsecCallProfiles || bcOffset >= m_parsecProfileSize)
+            return nullptr;
+        return &m_parsecCallProfiles[bcOffset];
+    }

+    // Allocate all profile arrays — called once when code first becomes warm
+    void allocateParsecProfiles()
+    {
+        if (m_parsecTypeProfiles) return; // already allocated
+        unsigned size = instructions().size();
+        m_parsecProfileSize    = size;
+        m_parsecTypeProfiles   = new ParsecTypeProfile[size]();
+        m_parsecBinaryProfiles = new ParsecBinaryProfile[size]();
+        m_parsecArrayProfiles  = new ParsecArrayProfile[size]();
+        m_parsecCallProfiles   = new ParsecCallProfile[size]();
+    }

+    // Free profile arrays on CodeBlock destruction
+    void freeParsecProfiles()
+    {
+        delete[] m_parsecTypeProfiles;   m_parsecTypeProfiles   = nullptr;
+        delete[] m_parsecBinaryProfiles; m_parsecBinaryProfiles = nullptr;
+        delete[] m_parsecArrayProfiles;  m_parsecArrayProfiles  = nullptr;
+        delete[] m_parsecCallProfiles;   m_parsecCallProfiles   = nullptr;
+    }

+private:
+    ParsecTypeProfile*   m_parsecTypeProfiles   { nullptr };
+    ParsecBinaryProfile* m_parsecBinaryProfiles { nullptr };
+    ParsecArrayProfile*  m_parsecArrayProfiles  { nullptr };
+    ParsecCallProfile*   m_parsecCallProfiles   { nullptr };
+    unsigned             m_parsecProfileSize    { 0 };
+public:
+#endif // ENABLE(PARSEC_TYPE_FEEDBACK)

