diff --git a/Source/JavaScriptCore/pmj/PMJPlan.h b/Source/JavaScriptCore/pmj/PMJPlan.h
new file mode 100644
--- /dev/null
+++ b/Source/JavaScriptCore/pmj/PMJPlan.h
@@ -0,0 +1,75 @@
+#pragma once
+// ================================================================
+//  PMJPlan.h
+//  The compilation plan object that JITWorklist enqueues for PMJ.
+//  Mirrors DFGPlan and BaselineJITPlan in structure.
+//
+//  Lifecycle:
+//    1. JITWorklist::enqueueForPMJ() creates a PMJPlan and adds it to queue
+//    2. Worker thread calls PMJPlan::compileInBackground()
+//    3. Main thread calls PMJPlan::installCode() to swap in the PMJ code
+// ================================================================
+
+#include "PMJCompiler.h"
+#include "CodeBlock.h"
+#include <wtf/RefCounted.h>
+#include <wtf/ThreadSafeRefCounted.h>
+
+namespace JSC {
+
+class VM;
+
+namespace PMJ {
+
+enum class PMJPlanStage : uint8_t {
+    Queued,
+    Compiling,
+    ReadyToInstall,
+    Installed,
+    Failed,
+};
+
+class PMJPlan : public ThreadSafeRefCounted<PMJPlan> {
+public:
+    static Ref<PMJPlan> create(CodeBlock* codeBlock, VM& vm)
+    {
+        return adoptRef(*new PMJPlan(codeBlock, vm));
+    }

+    // Called on JIT worker thread — compiles without holding VM lock
+    void compileInBackground();

+    // Called on main thread with VM lock held — installs compiled code
+    // Returns true if installation succeeded
+    bool installCode(VM&);

+    CodeBlock* codeBlock() const { return m_codeBlock.get(); }
+    PMJPlanStage stage() const { return m_stage; }
+    bool isReadyToInstall() const { return m_stage == PMJPlanStage::ReadyToInstall; }
+    bool failed() const { return m_stage == PMJPlanStage::Failed; }

+private:
+    PMJPlan(CodeBlock* cb, VM& vm)
+        : m_codeBlock(cb)
+        , m_vm(vm)
+    {}

+    // Weak reference — CodeBlock may be collected before we install.
+    // JSC CodeBlock uses its own GC-aware weak reference mechanism.
+    // WeakCodeBlockPtr is the correct type: it's a WeakHandleOwner-backed
+    // weak ref that becomes null when the CodeBlock is collected.
+    // Do NOT use WTF::WeakPtr<CodeBlock> — CodeBlock doesn't inherit CanMakeWeakPtr.
+    WeakCodeBlockPtr  m_codeBlock;
+    VM&               m_vm;
+    PMJResult         m_result;
+    PMJPlanStage      m_stage { PMJPlanStage::Queued };
+};

+}} // JSC::PMJ

diff --git a/Source/JavaScriptCore/pmj/PMJPlan.cpp b/Source/JavaScriptCore/pmj/PMJPlan.cpp
new file mode 100644
--- /dev/null
+++ b/Source/JavaScriptCore/pmj/PMJPlan.cpp
@@ -0,0 +1,75 @@
+#include "config.h"
+#include "PMJPlan.h"
+#include "CodeBlock.h"
+#include "JITCode.h"
+
+namespace JSC { namespace PMJ {
+
+void PMJPlan::compileInBackground()
+{
+    m_stage = PMJPlanStage::Compiling;

+    // Grab a strong ref to CodeBlock — if it gets GC'd before we finish,
+    // abort compilation rather than crash.
+    // WeakCodeBlockPtr dereferences via get() which returns nullptr if collected.
+    CodeBlock* cb = m_codeBlock.get();
+    if (!cb) {
+        m_stage = PMJPlanStage::Failed;
+        return;
+    }

+    // Run compilation — no VM lock held, fully thread-safe
+    m_result = compileFunction(cb);

+    if (m_result.succeeded)
+        m_stage = PMJPlanStage::ReadyToInstall;
+    else {
+        WTFLogAlways("PMJ: compilation failed for %s: %s",
+            cb->inferredName().utf8().data(),
+            m_result.failReason.utf8().data());
+        m_stage = PMJPlanStage::Failed;
+    }
+}

+bool PMJPlan::installCode(VM& vm)
+{
+    ASSERT(isReadyToInstall());
+    ASSERT(m_result.code);

+    // WeakCodeBlockPtr.get() returns raw ptr, null if collected
+    CodeBlock* cb = m_codeBlock.get();
+    if (!cb) return false; // CodeBlock was collected — discard

+    // Only install if CodeBlock is still at Baseline tier
+    // (it may have already been promoted to DFG while PMJ was compiling)
+    if (cb->jitType() != JITType::BaselineJIT) {
+        m_stage = PMJPlanStage::Failed;
+        return false;
+    }

+    // Atomically replace the Baseline JIT code with PMJ code
+    cb->setJITCode(WTFMove(m_result.code));
+    m_stage = PMJPlanStage::Installed;

+    WTFLogAlways("PMJ: installed for %s (%zu bytes)",
+        cb->inferredName().utf8().data(),
+        m_result.code ? 0 : 0); // size logged by JITCode

+    return true;
+}

+}} // JSC::PMJ

