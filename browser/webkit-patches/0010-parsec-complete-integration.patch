diff --git a/Source/JavaScriptCore/jit/ParsecProfilingOperations.cpp b/Source/JavaScriptCore/jit/ParsecProfilingOperations.cpp
new file mode 100644
--- /dev/null
+++ b/Source/JavaScriptCore/jit/ParsecProfilingOperations.cpp
@@ -0,0 +1,55 @@
+#include "config.h"
+// ================================================================
+//  ParsecProfilingOperations.cpp
+//  C++ implementations of the profiling helpers called from Baseline JIT.
+//  These are linked into JavaScriptCore and called via callOperation().
+//  Keeping them in a separate TU avoids circular dependencies.
+// ================================================================
+
+#include "ParsecTypeProfile.h"
+#include "CodeBlock.h"
+#include "JSValue.h"
+#include "JSArray.h"
+
+namespace JSC {
+
+// ── Ensure profiles exist and allocate if needed ──────────────────
+static inline void ensureProfiles(CodeBlock* cb)
+{
+#if ENABLE(PARSEC_TYPE_FEEDBACK)
+    if (UNLIKELY(!cb->parsecTypeProfileForOffset(0)))
+        cb->allocateParsecProfiles();
+#endif
+}

+// ── Record binary operation profile ──────────────────────────────
+JSC_DEFINE_JIT_OPERATION(operationParsecRecordBinaryProfile,
+    void, (CodeBlock* cb, uint32_t bco, EncodedJSValue lhsEnc, EncodedJSValue rhsEnc))
+{
+    ensureProfiles(cb);
+    auto* profile = cb->parsecBinaryProfileForOffset(bco);
+    if (!profile) return;
+    JSValue lhs = JSValue::decode(lhsEnc);
+    JSValue rhs = JSValue::decode(rhsEnc);
+    profile->observe(ptcFromJSValue(lhs), ptcFromJSValue(rhs), PTC::Unknown);
+}

+// ── Record general type at any site ──────────────────────────────
+JSC_DEFINE_JIT_OPERATION(operationParsecRecordTypeProfile,
+    void, (CodeBlock* cb, uint32_t bco, EncodedJSValue enc))
+{
+    ensureProfiles(cb);
+    auto* profile = cb->parsecTypeProfileForOffset(bco);
+    if (!profile) return;
+    profile->observeValue(JSValue::decode(enc));
+}

+// ── Record call site callee ───────────────────────────────────────
+JSC_DEFINE_JIT_OPERATION(operationParsecRecordCallProfile,
+    void, (CodeBlock* cb, uint32_t bco, EncodedJSValue calleeEnc))
+{
+    ensureProfiles(cb);
+    auto* profile = cb->parsecCallProfileForOffset(bco);
+    if (!profile) return;
+    JSValue callee = JSValue::decode(calleeEnc);
+    profile->observe(callee, nullptr, 0);
+}

+// ── PMJ tier-up trigger ───────────────────────────────────────────
+JSC_DEFINE_JIT_OPERATION(operationEnqueueForPMJ, void, (CodeBlock* cb))
+{
+    VM& vm = cb->vm();
+    vm.jitWorklist().enqueueForPMJ(cb, vm);
+}

+} // namespace JSC
