+    // ── Type accessors for PMJCompiler ────────────────────────────────
+    // Returns the PTC tag of the most-observed lhs/rhs type.
+    // PMJCompiler casts this to PMJType — the enums are intentionally aligned.
+    uint8_t dominantLhsType() const {
+        TypePair const* best = nullptr;
+        for (auto& p : m_pairs)
+            if (p.count > 0 && (!best || p.count > best->count)) best = &p;
+        return best ? static_cast<uint8_t>(best->lhs) : 0;
+    }
+    uint8_t dominantRhsType() const {
+        TypePair const* best = nullptr;
+        for (auto& p : m_pairs)
+            if (p.count > 0 && (!best || p.count > best->count)) best = &p;
+        return best ? static_cast<uint8_t>(best->rhs) : 0;
+    }

