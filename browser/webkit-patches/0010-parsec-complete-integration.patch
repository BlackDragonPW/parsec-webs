diff --git a/Source/JavaScriptCore/jit/JITWorklist.cpp b/Source/JavaScriptCore/jit/JITWorklist.cpp
--- a/Source/JavaScriptCore/jit/JITWorklist.cpp
+++ b/Source/JavaScriptCore/jit/JITWorklist.cpp
@@ -1,5 +1,6 @@
 #include "config.h"
 #include "JITWorklist.h"
+#include "PMJPlan.h"
 
 namespace JSC {
 
@@ -120,4 +121,60 @@ void JITWorklist::enqueueForDFG(CodeBlock* codeBlock)
 {
+
+// ── PMJ scheduling ────────────────────────────────────────────────

+void JITWorklist::enqueueForPMJ(CodeBlock* codeBlock, VM& vm)
+{
+    // Allocate Parsec profiles now if not already done —
+    // Baseline instrumentation stubs need them populated before PMJ compiles
+#if ENABLE(PARSEC_TYPE_FEEDBACK)
+    codeBlock->allocateParsecProfiles();
+#endif

+    auto plan = PMJ::PMJPlan::create(codeBlock, vm);

+    // Compile on a background thread from the existing JIT thread pool.
+    // JITWorklist uses m_worklist (a Ref<Worklist>) internally.
+    // We submit via the Worklist's enqueue method.
+    worklist().enqueue(plan, [plan]() mutable {
+        plan->compileInBackground();
+    });

+    Locker locker { m_pmjQueueLock };
+    m_pmjQueue.append(WTFMove(plan));
+}

+void JITWorklist::installPMJPlans(VM& vm)
+{
+    // Called from the main thread at GC safepoints and before DFG compilation.
+    // Install any finished PMJ plans.
+    Vector<Ref<PMJ::PMJPlan>> toInstall;
+    {
+        Locker locker { m_pmjQueueLock };
+        m_pmjQueue.removeAllMatching([&](auto& plan) {
+            if (plan->isReadyToInstall()) {
+                toInstall.append(plan.copyRef());
+                return true; // remove from queue
+            }
+            if (plan->failed())
+                return true; // discard failed plans
+            return false; // keep compiling plans in queue
+        });
+    }

+    for (auto& plan : toInstall)
+        plan->installCode(vm);
+}

diff --git a/Source/JavaScriptCore/jit/BaselineJITGen.cpp b/Source/JavaScriptCore/jit/BaselineJITGen.cpp
--- a/Source/JavaScriptCore/jit/BaselineJITGen.cpp
+++ b/Source/JavaScriptCore/jit/BaselineJITGen.cpp
@@ -1,5 +1,6 @@
 #include "config.h"
 #include "JIT.h"
+#include "ParsecTypeProfile.h"
 
 namespace JSC {
 
@@ -200,6 +201,90 @@ void JIT::emit_op_add(const Instruction* pc)
 {
+#if ENABLE(PARSEC_TYPE_FEEDBACK)
+    // ── Parsec profiling instrumentation ─────────────────────────────
+    //
+    // After computing the result of op_add, record the operand types in
+    // ParsecBinaryProfile. This runs at Baseline JIT speed and is cheap:
+    // a function call to a C++ helper (similar to ValueProfile recording).
+    //
+    // The helper is called with: codeBlock, bytecodeOffset, lhsJSValue, rhsJSValue
+    // It classifies each value's type and records the pair in the profile.
+    //
+    // We instrument op_add here as the representative case. The same pattern
+    // applies to op_sub, op_mul, etc. — each arithmetic op gets its own
+    // profiling call emitted inline by the Baseline JIT.

+    auto bytecodeOffset = m_bytecodeIndex.offset();
+    // Emit: call parsec_record_binary_profile(codeBlock, offset, lhsValue, rhsValue)
+    // Register convention: arguments in standard calling convention
+    emitGetVirtualRegister(pc->as<OpAdd>().m_lhs, regT2);
+    emitGetVirtualRegister(pc->as<OpAdd>().m_rhs, regT3);
+    callOperation(
+        operationParsecRecordBinaryProfile,
+        m_codeBlock,
+        TrustedImm32(bytecodeOffset),
+        regT2,   // lhs JSValue
+        regT3    // rhs JSValue
+    );

+    // Also record result type after computation
+    emitGetVirtualRegister(pc->as<OpAdd>().m_dst, regT2);
+    callOperation(
+        operationParsecRecordTypeProfile,
+        m_codeBlock,
+        TrustedImm32(bytecodeOffset),
+        regT2    // result JSValue
+    );
+#endif // ENABLE(PARSEC_TYPE_FEEDBACK)
+
+    // ── PMJ tier-up check ─────────────────────────────────────────────
+    // After profiling, check if we should enqueue this function for PMJ.
+    // This mirrors the existing DFG tier-up counter check.
+#if ENABLE(PARSEC_MIDTIER_JIT)
+    addPtr(TrustedImm32(Options::executionCounterIncrementForReturn()),
+           AbsoluteAddress(m_codeBlock->addressOfJITExecuteCounter()));
+    Jump dontOptimize = branchPtr(
+        Below,
+        AbsoluteAddress(m_codeBlock->addressOfJITExecuteCounter()),
+        TrustedImmPtr(reinterpret_cast<void*>(
+            static_cast<intptr_t>(Options::thresholdForPMJAfterWarmUp()))));
+    // Threshold reached — enqueue for PMJ on background thread
+    callOperation(operationEnqueueForPMJ, m_codeBlock);
+    dontOptimize.link(this);
+#endif
+}

+// ── C++ helpers called from Baseline JIT instrumentation stubs ────
+
+#if ENABLE(PARSEC_TYPE_FEEDBACK)
+// Record operand types for a binary operation
+extern "C" void operationParsecRecordBinaryProfile(
+    CodeBlock* codeBlock, uint32_t bcOffset, EncodedJSValue lhs, EncodedJSValue rhs)
+{
+    auto* profile = codeBlock->parsecBinaryProfileForOffset(bcOffset);
+    if (!profile) return;
+    JSValue l = JSValue::decode(lhs);
+    JSValue r = JSValue::decode(rhs);
+    PTC lhsTag = ptcFromJSValue(l);
+    PTC rhsTag = ptcFromJSValue(r);
+    // Result type is unknown at lhs/rhs recording time — updated by recordTypeProfile
+    profile->observe(lhsTag, rhsTag, PTC::Unknown);
+}

+// Record result type at any bytecode site
+extern "C" void operationParsecRecordTypeProfile(
+    CodeBlock* codeBlock, uint32_t bcOffset, EncodedJSValue value)
+{
+    auto* profile = codeBlock->parsecTypeProfileForOffset(bcOffset);
+    if (!profile) return;
+    JSValue v = JSValue::decode(value);
+    profile->observeValue(v);
+}
+#endif // ENABLE(PARSEC_TYPE_FEEDBACK)

+// Record call site callee
+#if ENABLE(PARSEC_TYPE_FEEDBACK)
+extern "C" void operationParsecRecordCallProfile(
+    CodeBlock* codeBlock, uint32_t bcOffset, EncodedJSValue callee)
+{
+    auto* profile = codeBlock->parsecCallProfileForOffset(bcOffset);
+    if (!profile) return;
+    JSValue v = JSValue::decode(callee);
+    profile->observe(v, nullptr, 0);
+}
+#endif

+#if ENABLE(PARSEC_MIDTIER_JIT)
+// Tier-up helper: enqueue CodeBlock for PMJ on background thread
+extern "C" void operationEnqueueForPMJ(CodeBlock* codeBlock)
+{
+    VM& vm = codeBlock->vm();
+    // JSC exposes the JIT worklist as a global singleton, not a VM member.
+    // JITWorklist::ensureGlobalWorklist() is the correct accessor in all
+    // WebKit versions. vm.jitWorklist() does not exist.
+    JITWorklist::ensureGlobalWorklist().enqueueForPMJ(codeBlock, vm);
+}
+#endif

