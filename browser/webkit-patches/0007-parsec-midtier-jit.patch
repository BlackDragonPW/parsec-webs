diff --git a/Source/JavaScriptCore/pmj/PMJLinearIR.h b/Source/JavaScriptCore/pmj/PMJLinearIR.h
new file mode 100644
--- /dev/null
+++ b/Source/JavaScriptCore/pmj/PMJLinearIR.h
@@ -0,0 +1,210 @@
+#pragma once
+// ================================================================
+//  PMJLinearIR.h — Parsec Mid-tier JIT Linear Intermediate Representation
+//
+//  A flat list of typed instructions. No SSA, no PHI nodes, no dominance
+//  tree. This keeps compilation O(n) and is sufficient for the optimizations
+//  PMJ performs (unboxing, monomorphic speculation, direct property access).
+//
+//  Each PMJValue is either:
+//    - Unboxed: Int32, Double, Boolean, Null, Undefined — lives in a register
+//    - Boxed: JSValue — lives in a register as a 64-bit encoded value
+//    - Address: a pointer to a JS object — lives in a register
+// ================================================================
+
+#include <wtf/Vector.h>
+#include <wtf/text/WTFString.h>
+#include "MacroAssembler.h"
+
+namespace JSC { namespace PMJ {
+
+// ── Value types understood by PMJ ─────────────────────────────────
+enum class PMJType : uint8_t {
+    Unknown,      // Not yet known — boxed JSValue
+    Int32,        // Definitely int32 — unboxed
+    Double,       // Definitely double — unboxed
+    Boolean,      // Definitely boolean — unboxed
+    Null,
+    Undefined,
+    Object,       // Definitely an object — pointer
+    String,       // Definitely a string — pointer
+    JSValue,      // Boxed 64-bit encoding
+};
+
+inline bool isUnboxed(PMJType t) {
+    return t == PMJType::Int32 || t == PMJType::Double || t == PMJType::Boolean;
+}
+
+// ── Virtual register ──────────────────────────────────────────────
+struct VReg {
+    uint16_t index { 0xFFFF };
+    PMJType  type  { PMJType::Unknown };
+    bool     isConst { false };
+    bool valid() const { return index != 0xFFFF; }
+};
+
+// ── Instruction opcodes ───────────────────────────────────────────
+enum class PMJOp : uint8_t {
+    // Moves
+    Mov, MovImm, LoadArg, StoreArg,
+
+    // Unboxed integer arithmetic
+    AddInt, SubInt, MulInt, DivInt, ModInt,
+    NegInt, IncInt, DecInt,
+    AndInt, OrInt, XorInt, ShlInt, ShrInt, UshrInt,
+
+    // Unboxed double arithmetic
+    AddDbl, SubDbl, MulDbl, DivDbl, NegDbl,
+    SqrtDbl, AbsDbl, FloorDbl, CeilDbl, RoundDbl,
+
+    // Comparisons (produce unboxed boolean)
+    CmpEqInt, CmpNeInt, CmpLtInt, CmpLeInt, CmpGtInt, CmpGeInt,
+    CmpEqDbl, CmpNeDbl, CmpLtDbl, CmpLeDbl, CmpGtDbl, CmpGeDbl,
+    CmpEqJSVal, CmpStrictEqJSVal,
+
+    // Type guards — deoptimize to Baseline if guard fails
+    GuardInt32,   // check JSValue is int32, unbox it
+    GuardDouble,  // check JSValue is double, unbox it
+    GuardObject,  // check JSValue is object
+    GuardString,  // check JSValue is string
+    GuardBool,    // check JSValue is boolean
+    GuardNotNull,
+    GuardStructure, // check object's structure ID matches expected
+
+    // Boxing / unboxing
+    BoxInt32,
+    BoxDouble,
+    BoxBoolean,
+    UnboxInt32,
+    UnboxDouble,
+
+    // Property access (specialized)
+    GetPropertyDirect,  // object[knownOffset] — no IC, direct load
+    SetPropertyDirect,  // object[knownOffset] = value
+    GetPropertyIC,      // fallback to IC
+    SetPropertyIC,

+    // Array access
+    GetArrayElement,    // array[knownIndex] with bounds check
+    SetArrayElement,
+    GetArrayLength,     // array.length — direct load from header

+    // Calls
+    CallDirect,     // direct call to known function pointer
+    CallIC,         // polymorphic call via IC
+    CallBuiltin,    // known JSC builtin (Math.sin, Array.push, etc.)
+    TailCall,
+    Return,
+
+    // Control flow
+    Jump, JumpIfTrue, JumpIfFalse,
+    JumpIfInt32, JumpIfDouble,   // type-checked branches
+
+    // OSR
+    OSREnter,   // entry point for OSR from Baseline
+    OSRExit,    // deoptimize — fall back to Baseline/LLInt
+
+    // Misc
+    CheckWatchpoint, // invalidate if prototype chain changes
+    Nop,
+};
+
+// ── Single instruction ────────────────────────────────────────────
+struct PMJInstr {
+    PMJOp  op;
+    VReg   dst;
+    VReg   src1;
+    VReg   src2;
+    VReg   src3;
+
+    // Immediate operands
+    union {
+        int32_t  immInt;
+        double   immDbl;
+        uint32_t immUint;
+        uint64_t immUint64;
+    };
+
+    uint32_t bytecodeOffset { 0 };  // for deopt stack frames
+
+    // For GuardStructure: expected structure ID
+    uint32_t expectedStructureID { 0 };
+
+    // For property access: slot offset in bytes from object base
+    uint16_t propertyOffset { 0 };
+
+    // For calls: number of arguments
+    uint8_t  argc { 0 };
+
+    // Deoptimization exit label (patched during code emission)
+    MacroAssembler::Label deoptLabel;
+};
+
+// ── Basic block ───────────────────────────────────────────────────
+struct PMJBlock {
+    uint32_t         bytecodeStart { 0 };
+    uint32_t         bytecodeEnd   { 0 };
+    Vector<PMJInstr> instrs;
+    Vector<uint32_t> successors;   // indices into PMJFunction::blocks
+    Vector<uint32_t> predecessors;
+    bool             isOSREntry { false };
+};
+
+// ── Function-level IR ─────────────────────────────────────────────
+struct PMJFunction {
+    Vector<PMJBlock> blocks;
+    uint32_t         numVRegs { 0 };
+    uint32_t         numArgs  { 0 };
+    // Type annotations from IC feedback (vreg → inferred type)
+    Vector<PMJType>  inferredTypes;
+
+    PMJBlock& entry() { return blocks[0]; }
+    VReg newVReg(PMJType t = PMJType::Unknown) {
+        VReg v; v.index = numVRegs++; v.type = t;
+        inferredTypes.append(t);
+        return v;
+    }
+};
+
+}} // JSC::PMJ

+diff --git a/Source/JavaScriptCore/pmj/PMJRA.h b/Source/JavaScriptCore/pmj/PMJRA.h
+new file mode 100644
+--- /dev/null
++++ b/Source/JavaScriptCore/pmj/PMJRA.h
+@@ -0,0 +1,95 @@
+#pragma once
+// ================================================================
+//  PMJRA.h — Linear Scan Register Allocator for PMJ
+//
+//  Linear scan is the classic fast register allocator:
+//    1. Compute live ranges for all virtual registers (one forward pass)
+//    2. Scan forward, assigning physical registers
+//    3. When all physical registers are taken, spill the value with
+//       the longest remaining live range ("farthest first" heuristic)
+//
+//  Compiles 5-10x faster than a graph-coloring allocator. DFG uses
+//  a more sophisticated allocator — PMJ's job is to be fast, not perfect.
+//  FTL handles the truly hot code anyway.
+// ================================================================
+
+#include "PMJLinearIR.h"
+#include "RegisterSet.h"
+#include <wtf/HashMap.h>
+
+namespace JSC { namespace PMJ {
+
+// Physical register assignment
+struct PhysReg {
+    enum Kind : uint8_t { GPR, FPR, Spill } kind;
+    union {
+        MacroAssembler::RegisterID     gpr;
+        MacroAssembler::FPRegisterID   fpr;
+        uint32_t                       spillOffset; // offset from frame pointer
+    };
+};
+
+// Live range for one virtual register
+struct LiveRange {
+    uint32_t start { 0 };  // instruction index where vreg is first defined
+    uint32_t end   { 0 };  // instruction index of last use
+    VReg     vreg;
+    PhysReg  assigned;
+    bool     isSpilled { false };
+};
+
+class LinearScanRA {
+public:
+    // Available physical registers (caller-saved preferred — avoids saves)
+    static constexpr MacroAssembler::RegisterID kGPRs[] = {
+        MacroAssembler::regT0, MacroAssembler::regT1, MacroAssembler::regT2,
+        MacroAssembler::regT3, MacroAssembler::regT4, MacroAssembler::regT5,
+    };
+    static constexpr MacroAssembler::FPRegisterID kFPRs[] = {
+        MacroAssembler::fpRegT0, MacroAssembler::fpRegT1,
+        MacroAssembler::fpRegT2, MacroAssembler::fpRegT3,
+    };
+    static constexpr unsigned kNumGPRs = 6;
+    static constexpr unsigned kNumFPRs = 4;
+
+    explicit LinearScanRA(PMJFunction& fn) : m_fn(fn) {}
+
+    // Run the allocator. After this, every VReg in m_fn has an assignment.
+    void allocate();
+
+    // Look up the physical assignment for a virtual register
+    PhysReg assignmentFor(VReg v) const;
+
+    // Stack frame size needed for spills (bytes, 16-byte aligned)
+    uint32_t spillAreaSize() const { return (m_nextSpillOffset + 15) & ~15u; }
+
+private:
+    void computeLiveRanges();
+    void linearScan();
+    void expireOldIntervals(uint32_t pos);
+    void spillAtInterval(LiveRange& current, uint32_t pos);
+    PhysReg allocateGPR();
+    PhysReg allocateFPR();
+    uint32_t allocateSpillSlot(uint32_t size);
+
+    PMJFunction&              m_fn;
+    Vector<LiveRange>         m_ranges;         // sorted by start
+    Vector<LiveRange*>        m_active;          // sorted by end
+    HashMap<uint16_t, PhysReg> m_assignment;     // vreg.index → PhysReg
+    uint32_t                  m_nextSpillOffset { 0 };
+};
+
+}} // JSC::PMJ

diff --git a/Source/JavaScriptCore/pmj/PMJRA.cpp b/Source/JavaScriptCore/pmj/PMJRA.cpp
new file mode 100644
--- /dev/null
+++ b/Source/JavaScriptCore/pmj/PMJRA.cpp
@@ -0,0 +1,175 @@
+#include "config.h"
+#include "PMJRA.h"
+#include <algorithm>
+
+namespace JSC { namespace PMJ {
+
+void LinearScanRA::allocate()
+{
+    computeLiveRanges();
+    // Sort live ranges by start position (linear scan requirement)
+    std::sort(m_ranges.begin(), m_ranges.end(),
+        [](const LiveRange& a, const LiveRange& b) { return a.start < b.start; });
+    linearScan();
+}
+
+void LinearScanRA::computeLiveRanges()
+{
+    // Flatten all blocks into one instruction stream for live range analysis
+    uint32_t pos = 0;
+    for (auto& block : m_fn.blocks) {
+        for (auto& instr : block.instrs) {
+            // Track definition
+            if (instr.dst.valid()) {
+                auto& range = m_ranges.at(instr.dst.index);
+                if (range.start == 0 && range.end == 0)
+                    range.start = pos;
+                range.vreg = instr.dst;
+            }
+            // Track last use for src operands
+            auto updateUse = [&](VReg v) {
+                if (!v.valid()) return;
+                while (m_ranges.size() <= v.index)
+                    m_ranges.append(LiveRange{});
+                m_ranges[v.index].end = pos;
+                m_ranges[v.index].vreg = v;
+            };
+            updateUse(instr.src1);
+            updateUse(instr.src2);
+            updateUse(instr.src3);
+            ++pos;
+        }
+    }
+}
+
+void LinearScanRA::linearScan()
+{
+    // Active: intervals currently occupying a physical register, sorted by end
+    m_active.clear();
+
+    for (auto& interval : m_ranges) {
+        if (interval.start == interval.end && interval.end == 0) continue;
+
+        expireOldIntervals(interval.start);
+
+        bool isFloat = (interval.vreg.type == PMJType::Double);
+
+        if (isFloat) {
+            if (m_active.size() >= kNumFPRs) {
+                spillAtInterval(interval, interval.start);
+            } else {
+                interval.assigned = allocateFPR();
+                m_active.append(&interval);
+                std::sort(m_active.begin(), m_active.end(),
+                    [](const LiveRange* a, const LiveRange* b) { return a->end < b->end; });
+            }
+        } else {
+            if (m_active.size() >= kNumGPRs) {
+                spillAtInterval(interval, interval.start);
+            } else {
+                interval.assigned = allocateGPR();
+                m_active.append(&interval);
+                std::sort(m_active.begin(), m_active.end(),
+                    [](const LiveRange* a, const LiveRange* b) { return a->end < b->end; });
+            }
+        }
+
+        m_assignment.set(interval.vreg.index, interval.assigned);
+    }
+}
+
+void LinearScanRA::expireOldIntervals(uint32_t pos)
+{
+    m_active.removeAllMatching([&](LiveRange* r) {
+        return r->end < pos;
+    });
+}
+
+void LinearScanRA::spillAtInterval(LiveRange& current, uint32_t pos)
+{
+    // Spill the interval with the farthest end point ("farthest first")
+    // If that's current, spill current; otherwise spill the active one.
+    auto* spill = &current;
+    for (auto* active : m_active) {
+        if (active->end > current.end) {
+            spill = active;
+            break;
+        }
+    }
+
+    if (spill == &current) {
+        // Spill current
+        current.isSpilled = true;
+        current.assigned.kind    = PhysReg::Spill;
+        current.assigned.spillOffset = allocateSpillSlot(8);
+        m_assignment.set(current.vreg.index, current.assigned);
+    } else {
+        // Give spill's register to current
+        current.assigned = spill->assigned;
+        m_assignment.set(current.vreg.index, current.assigned);
+        // Spill the other interval
+        spill->isSpilled = true;
+        spill->assigned.kind = PhysReg::Spill;
+        spill->assigned.spillOffset = allocateSpillSlot(8);
+        m_assignment.set(spill->vreg.index, spill->assigned);
+        m_active.removeFirst(spill);
+        m_active.append(&current);
+        std::sort(m_active.begin(), m_active.end(),
+            [](const LiveRange* a, const LiveRange* b) { return a->end < b->end; });
+    }
+}
+
+PhysReg LinearScanRA::allocateGPR()
+{
+    // Find a GPR not currently in use
+    for (unsigned i = 0; i < kNumGPRs; ++i) {
+        auto reg = kGPRs[i];
+        bool inUse = false;
+        for (auto* a : m_active) {
+            if (!a->isSpilled && a->assigned.kind == PhysReg::GPR && a->assigned.gpr == reg) {
+                inUse = true; break;
+            }
+        }
+        if (!inUse) {
+            PhysReg r; r.kind = PhysReg::GPR; r.gpr = reg; return r;
+        }
+    }
+    // Fallback — should not reach here if caller checked capacity
+    PhysReg r; r.kind = PhysReg::GPR; r.gpr = kGPRs[0]; return r;
+}
+
+PhysReg LinearScanRA::allocateFPR()
+{
+    for (unsigned i = 0; i < kNumFPRs; ++i) {
+        auto reg = kFPRs[i];
+        bool inUse = false;
+        for (auto* a : m_active) {
+            if (!a->isSpilled && a->assigned.kind == PhysReg::FPR && a->assigned.fpr == reg) {
+                inUse = true; break;
+            }
+        }
+        if (!inUse) {
+            PhysReg r; r.kind = PhysReg::FPR; r.fpr = reg; return r;
+        }
+    }
+    PhysReg r; r.kind = PhysReg::FPR; r.fpr = kFPRs[0]; return r;
+}
+
+uint32_t LinearScanRA::allocateSpillSlot(uint32_t size)
+{
+    uint32_t offset = m_nextSpillOffset;
+    m_nextSpillOffset += size;
+    return offset;
+}
+
+PhysReg LinearScanRA::assignmentFor(VReg v) const
+{
+    auto it = m_assignment.find(v.index);
+    if (it == m_assignment.end()) {
+        // Unassigned — return a default
+        PhysReg r; r.kind = PhysReg::GPR; r.gpr = MacroAssembler::regT0; return r;
+    }
+    return it->value;
+}
+
+}} // JSC::PMJ

diff --git a/Source/JavaScriptCore/pmj/PMJCompiler.h b/Source/JavaScriptCore/pmj/PMJCompiler.h
new file mode 100644
--- /dev/null
+++ b/Source/JavaScriptCore/pmj/PMJCompiler.h
@@ -0,0 +1,110 @@
+#pragma once
+// ================================================================
+//  PMJCompiler.h
+//  Translates bytecode + IC feedback into PMJ linear IR,
+//  then emits machine code using JSC's MacroAssembler.
+//
+//  Two phases:
+//    1. IRBuild: bytecode → PMJFunction (with type guards from IC)
+//    2. CodeGen:  PMJFunction → machine code (using PMJRA for registers)
+// ================================================================
+
+#include "PMJLinearIR.h"
+#include "PMJRA.h"
+#include "CodeBlock.h"
+#include "JITCode.h"
+#include "MacroAssembler.h"
+#include "StructureStubInfo.h"
+#include "CallLinkInfo.h"
+
+namespace JSC { namespace PMJ {
+
+// Result of a PMJ compilation
+struct PMJResult {
+    RefPtr<JITCode> code;
+    bool            succeeded { false };
+    String          failReason;
+};
+
+class PMJCompiler {
+public:
+    explicit PMJCompiler(CodeBlock* codeBlock)
+        : m_codeBlock(codeBlock)
+        , m_vm(codeBlock->vm())
+    {}
+
+    PMJResult compile();

+private:
+    // ── Phase 1: IR construction ──────────────────────────────────
+    bool buildIR();
+    void buildBlock(unsigned bytecodeOffset, PMJBlock&);
+    void emitBytecodeOp(const Instruction*, PMJBlock&);
+
+    // Type inference from IC feedback
+    PMJType inferTypeFromIC(unsigned bytecodeOffset, unsigned operandIndex);
+    PMJType inferTypeFromProfile(ValueProfile*);
+    bool    isMonomorphicCall(CallLinkInfo*);
+    bool    isMonomorphicAccess(StructureStubInfo*);
+    uint32_t getMonomorphicStructureID(StructureStubInfo*);
+    uint16_t getMonomorphicPropertyOffset(StructureStubInfo*);
+
+    // Emit type guard + unbox
+    VReg emitGuardAndUnbox(PMJBlock&, VReg src, PMJType expectedType,
+                            unsigned bytecodeOffset);
+
+    // ── Phase 2: Machine code emission ───────────────────────────
+    bool emitCode(PMJFunction&, MacroAssembler&, LinearScanRA&);
+    void emitInstr(const PMJInstr&, MacroAssembler&, LinearScanRA&);

+    // Per-opcode emitters
+    void emitArithInt(const PMJInstr&, MacroAssembler&, LinearScanRA&);
+    void emitArithDbl(const PMJInstr&, MacroAssembler&, LinearScanRA&);
+    void emitGuard(const PMJInstr&, MacroAssembler&, LinearScanRA&,
+                   Vector<MacroAssembler::Jump>& deoptJumps);
+    void emitPropertyGet(const PMJInstr&, MacroAssembler&, LinearScanRA&);
+    void emitPropertySet(const PMJInstr&, MacroAssembler&, LinearScanRA&);
+    void emitCall(const PMJInstr&, MacroAssembler&, LinearScanRA&);
+    void emitReturn(const PMJInstr&, MacroAssembler&, LinearScanRA&);
+    void emitOSRExit(MacroAssembler&, unsigned bytecodeOffset);

+    // Deoptimization: patch jump to Baseline JIT OSR entry
+    void linkDeoptExits(MacroAssembler&, Vector<MacroAssembler::Jump>&);

+    CodeBlock*    m_codeBlock;
+    VM&           m_vm;
+    PMJFunction   m_ir;

+    // Map from bytecodeOffset → PMJ block index
+    HashMap<uint32_t, uint32_t> m_bcToBlock;

+    // Deopt exit targets (bytecodeOffset → Baseline JIT address)
+    HashMap<uint32_t, MacroAssembler::Label> m_deoptTargets;
+};

+// ── PMJ compilation entry point ───────────────────────────────────
+// Called from JITWorklist when a function reaches PMJ threshold.
+PMJResult compileFunction(CodeBlock*);

+}} // JSC::PMJ

diff --git a/Source/JavaScriptCore/pmj/PMJCompiler.cpp b/Source/JavaScriptCore/pmj/PMJCompiler.cpp
new file mode 100644
--- /dev/null
+++ b/Source/JavaScriptCore/pmj/PMJCompiler.cpp
@@ -0,0 +1,380 @@
+#include "config.h"
+#include "PMJCompiler.h"
+#include "BytecodeStructs.h"
+#include "InterpreterInlines.h"
+#include "JITCode.h"
+#include "JSCInlines.h"
+#include "ValueProfile.h"
+#include "LinkBuffer.h"
+
+namespace JSC { namespace PMJ {
+
+PMJResult PMJCompiler::compile()
+{
+    // Bail out early if function is too large — let DFG handle it
+    if (m_codeBlock->instructions().size() > 10000) {
+        return { nullptr, false, "Function too large for PMJ"_s };
+    }
+
+    if (!buildIR()) {
+        return { nullptr, false, "IR construction failed"_s };
+    }
+
+    MacroAssembler masm;
+    LinearScanRA   ra(m_ir);
+    ra.allocate();
+
+    if (!emitCode(m_ir, masm, ra)) {
+        return { nullptr, false, "Code emission failed"_s };
+    }
+
+    // Link the generated code
+    LinkBuffer linkBuffer(masm, m_codeBlock, LinkBuffer::Profile::PMJ);
+    if (linkBuffer.didFailToAllocate()) {
+        return { nullptr, false, "LinkBuffer allocation failed"_s };
+    }
+
+    auto jitCode = adoptRef(*new DirectJITCode(
+        linkBuffer.finalizeCodeWithoutDisassembly(),
+        masm.entrypoint(),
+        JITType::PMJIT
+    ));
+
+    return { WTFMove(jitCode), true, { } };
+}
+
+bool PMJCompiler::buildIR()
+{
+    auto& instructions = m_codeBlock->instructions();
+    m_ir.numArgs = m_codeBlock->numParameters();

+    // Single-pass bytecode → IR translation
+    PMJBlock* currentBlock = nullptr;
+    uint32_t blockIdx = 0;

+    for (unsigned i = 0; i < instructions.size(); ) {
+        auto* pc = instructions.at(i).ptr();
+        auto opcode = Interpreter::getOpcodeID(*pc);

+        if (!currentBlock || m_bcToBlock.contains(i)) {
+            m_ir.blocks.append(PMJBlock{});
+            currentBlock = &m_ir.blocks.last();
+            currentBlock->bytecodeStart = i;
+            m_bcToBlock.set(i, m_ir.blocks.size() - 1);
+            blockIdx = m_ir.blocks.size() - 1;
+        }

+        emitBytecodeOp(pc, *currentBlock);
+        i += opcodeLengths[static_cast<unsigned>(opcode)];
+    }

+    return !m_ir.blocks.isEmpty();
+}

+void PMJCompiler::emitBytecodeOp(const Instruction* pc, PMJBlock& block)
+{
+    auto opcode = Interpreter::getOpcodeID(*pc);
+    unsigned bytecodeOffset = pc - m_codeBlock->instructions().at(0).ptr();

+    switch (opcode) {

+    // ── op_add ────────────────────────────────────────────────────
+    case op_add: {
+        auto bytecode = pc->as<OpAdd>();
+        VReg src1 = { (uint16_t)bytecode.m_lhs.offset(), PMJType::Unknown };
+        VReg src2 = { (uint16_t)bytecode.m_rhs.offset(), PMJType::Unknown };
+        VReg dst  = { (uint16_t)bytecode.m_dst.offset(), PMJType::Unknown };

+        // Check IC feedback for type specialization
+        auto* profile = m_codeBlock->valueProfileForOffset(bytecodeOffset);
+        PMJType lhsType = inferTypeFromProfile(profile);
+        PMJType rhsType = lhsType; // simplified — both sides likely same type

+        if (lhsType == PMJType::Int32) {
+            // Emit: guard lhs is Int32, guard rhs is Int32, add unboxed
+            VReg lhsUnboxed = emitGuardAndUnbox(block, src1, PMJType::Int32, bytecodeOffset);
+            VReg rhsUnboxed = emitGuardAndUnbox(block, src2, PMJType::Int32, bytecodeOffset);
+            VReg resultUnboxed = m_ir.newVReg(PMJType::Int32);
+            PMJInstr add;
+            add.op = PMJOp::AddInt;
+            add.dst = resultUnboxed;
+            add.src1 = lhsUnboxed;
+            add.src2 = rhsUnboxed;
+            add.bytecodeOffset = bytecodeOffset;
+            block.instrs.append(add);
+            // Box result back to JSValue
+            PMJInstr box;
+            box.op = PMJOp::BoxInt32;
+            box.dst = dst;
+            box.src1 = resultUnboxed;
+            block.instrs.append(box);
+        } else if (lhsType == PMJType::Double) {
+            VReg lhsU = emitGuardAndUnbox(block, src1, PMJType::Double, bytecodeOffset);
+            VReg rhsU = emitGuardAndUnbox(block, src2, PMJType::Double, bytecodeOffset);
+            VReg resU = m_ir.newVReg(PMJType::Double);
+            PMJInstr add; add.op = PMJOp::AddDbl; add.dst = resU; add.src1 = lhsU; add.src2 = rhsU;
+            block.instrs.append(add);
+            PMJInstr box; box.op = PMJOp::BoxDouble; box.dst = dst; box.src1 = resU;
+            block.instrs.append(box);
+        } else {
+            // Unknown type — emit a generic add via IC (no specialization)
+            PMJInstr add; add.op = PMJOp::CallBuiltin; add.dst = dst;
+            add.src1 = src1; add.src2 = src2; add.bytecodeOffset = bytecodeOffset;
+            block.instrs.append(add);
+        }
+        break;
+    }

+    // ── op_get_by_id ─────────────────────────────────────────────
+    case op_get_by_id: {
+        auto bytecode = pc->as<OpGetById>();
+        VReg base = { (uint16_t)bytecode.m_base.offset(), PMJType::Unknown };
+        VReg dst  = { (uint16_t)bytecode.m_dst.offset(),  PMJType::Unknown };

+        // Try monomorphic structure specialization
+        auto* stubInfo = m_codeBlock->findStubInfo(CodeOrigin(bytecodeOffset));
+        if (stubInfo && isMonomorphicAccess(stubInfo)) {
+            uint32_t structID    = getMonomorphicStructureID(stubInfo);
+            uint16_t propOffset  = getMonomorphicPropertyOffset(stubInfo);

+            // Guard: object has expected structure
+            PMJInstr guard;
+            guard.op = PMJOp::GuardStructure;
+            guard.src1 = base;
+            guard.expectedStructureID = structID;
+            guard.bytecodeOffset = bytecodeOffset;
+            block.instrs.append(guard);

+            // Direct property load: no IC lookup
+            PMJInstr load;
+            load.op = PMJOp::GetPropertyDirect;
+            load.dst = dst;
+            load.src1 = base;
+            load.propertyOffset = propOffset;
+            block.instrs.append(load);
+        } else {
+            // Polymorphic or cold — fall back to IC
+            PMJInstr get; get.op = PMJOp::GetPropertyIC; get.dst = dst; get.src1 = base;
+            get.bytecodeOffset = bytecodeOffset;
+            block.instrs.append(get);
+        }
+        break;
+    }

+    // ── op_call ──────────────────────────────────────────────────
+    case op_call: {
+        auto bytecode = pc->as<OpCall>();
+        VReg callee = { (uint16_t)bytecode.m_callee.offset(), PMJType::Unknown };
+        VReg dst    = { (uint16_t)bytecode.m_dst.offset(),    PMJType::Unknown };

+        auto* callInfo = m_codeBlock->getCallLinkInfo(bytecodeOffset);
+        if (callInfo && isMonomorphicCall(callInfo)) {
+            // Direct call — skip polymorphic dispatch
+            PMJInstr call;
+            call.op   = PMJOp::CallDirect;
+            call.dst  = dst;
+            call.src1 = callee;
+            call.argc = bytecode.m_argc;
+            call.bytecodeOffset = bytecodeOffset;
+            block.instrs.append(call);
+        } else {
+            PMJInstr call;
+            call.op   = PMJOp::CallIC;
+            call.dst  = dst;
+            call.src1 = callee;
+            call.argc = bytecode.m_argc;
+            call.bytecodeOffset = bytecodeOffset;
+            block.instrs.append(call);
+        }
+        break;
+    }

+    // ── op_ret ───────────────────────────────────────────────────
+    case op_ret: {
+        auto bytecode = pc->as<OpRet>();
+        VReg retVal = { (uint16_t)bytecode.m_value.offset(), PMJType::Unknown };
+        PMJInstr ret; ret.op = PMJOp::Return; ret.src1 = retVal;
+        ret.bytecodeOffset = bytecodeOffset;
+        block.instrs.append(ret);
+        break;
+    }

+    default:
+        // Unhandled opcode — emit OSR exit to Baseline for this bytecode offset
+        PMJInstr exit; exit.op = PMJOp::OSRExit; exit.bytecodeOffset = bytecodeOffset;
+        block.instrs.append(exit);
+        break;
+    }
+}

+VReg PMJCompiler::emitGuardAndUnbox(PMJBlock& block, VReg src, PMJType type, unsigned bcOffset)
+{
+    // Emit guard
+    PMJInstr guard;
+    switch (type) {
+    case PMJType::Int32:   guard.op = PMJOp::GuardInt32;  break;
+    case PMJType::Double:  guard.op = PMJOp::GuardDouble; break;
+    case PMJType::Boolean: guard.op = PMJOp::GuardBool;   break;
+    default:               guard.op = PMJOp::GuardInt32;  break;
+    }
+    guard.src1 = src;
+    guard.bytecodeOffset = bcOffset;
+    block.instrs.append(guard);

+    // Emit unbox
+    VReg unboxed = m_ir.newVReg(type);
+    PMJInstr unbox;
+    unbox.op   = (type == PMJType::Double) ? PMJOp::UnboxDouble : PMJOp::UnboxInt32;
+    unbox.dst  = unboxed;
+    unbox.src1 = src;
+    block.instrs.append(unbox);
+    return unboxed;
+}

+PMJType PMJCompiler::inferTypeFromProfile(ValueProfile* profile)
+{
+    if (!profile) return PMJType::Unknown;
+    SpeculatedType type = profile->computeUpdatedPrediction(m_codeBlock->globalObject());
+    if (isInt32Speculation(type))    return PMJType::Int32;
+    if (isDoubleSpeculation(type))   return PMJType::Double;
+    if (isBooleanSpeculation(type))  return PMJType::Boolean;
+    if (isCellSpeculation(type))     return PMJType::Object;
+    if (isStringSpeculation(type))   return PMJType::String;
+    return PMJType::Unknown;
+}

+bool PMJCompiler::isMonomorphicAccess(StructureStubInfo* si)
+{
+    return si && si->accessType() == AccessType::GetById
+        && si->cacheType() == CacheType::Stub
+        && si->stubInfoCount() == 1;
+}

+bool PMJCompiler::isMonomorphicCall(CallLinkInfo* cli)
+{
+    return cli && cli->isLinked() && !cli->isPolymorphic();
+}

+uint32_t PMJCompiler::getMonomorphicStructureID(StructureStubInfo* si)
+{
+    if (!si || si->stubInfoCount() == 0) return 0;
+    return si->firstAccessedStructureID();
+}

+uint16_t PMJCompiler::getMonomorphicPropertyOffset(StructureStubInfo* si)
+{
+    if (!si) return 0;
+    return static_cast<uint16_t>(si->inlineAccessBaseStructureOffset());
+}

+bool PMJCompiler::emitCode(PMJFunction& fn, MacroAssembler& masm, LinearScanRA& ra)
+{
+    Vector<MacroAssembler::Jump> deoptJumps;

+    // Function prologue
+    masm.emitFunctionPrologue();
+    masm.subPtr(MacroAssembler::TrustedImm32(ra.spillAreaSize()), MacroAssembler::stackPointerRegister);

+    for (auto& block : fn.blocks) {
+        for (auto& instr : block.instrs) {
+            emitInstr(instr, masm, ra);
+        }
+    }

+    // Link deopt exits back to Baseline JIT
+    linkDeoptExits(masm, deoptJumps);
+    return true;
+}

+void PMJCompiler::emitInstr(const PMJInstr& instr, MacroAssembler& masm, LinearScanRA& ra)
+{
+    switch (instr.op) {

+    case PMJOp::AddInt: {
+        auto dst  = ra.assignmentFor(instr.dst);
+        auto src1 = ra.assignmentFor(instr.src1);
+        auto src2 = ra.assignmentFor(instr.src2);
+        ASSERT(dst.kind == PhysReg::GPR && src1.kind == PhysReg::GPR && src2.kind == PhysReg::GPR);
+        if (src1.gpr != dst.gpr) masm.move(src1.gpr, dst.gpr);
+        masm.add32(src2.gpr, dst.gpr);
+        break;
+    }

+    case PMJOp::AddDbl: {
+        auto dst  = ra.assignmentFor(instr.dst);
+        auto src1 = ra.assignmentFor(instr.src1);
+        auto src2 = ra.assignmentFor(instr.src2);
+        ASSERT(dst.kind == PhysReg::FPR);
+        if (src1.fpr != dst.fpr) masm.moveDouble(src1.fpr, dst.fpr);
+        masm.addDouble(src2.fpr, dst.fpr);
+        break;
+    }

+    case PMJOp::SubInt: {
+        auto dst = ra.assignmentFor(instr.dst); auto s1 = ra.assignmentFor(instr.src1); auto s2 = ra.assignmentFor(instr.src2);
+        if (s1.gpr != dst.gpr) masm.move(s1.gpr, dst.gpr);
+        masm.sub32(s2.gpr, dst.gpr);
+        break;
+    }

+    case PMJOp::MulInt: {
+        auto dst = ra.assignmentFor(instr.dst); auto s1 = ra.assignmentFor(instr.src1); auto s2 = ra.assignmentFor(instr.src2);
+        if (s1.gpr != dst.gpr) masm.move(s1.gpr, dst.gpr);
+        masm.mul32(s2.gpr, dst.gpr);
+        break;
+    }

+    case PMJOp::GuardInt32: {
+        // Check that JSValue tag is Int32 — if not, OSR exit
+        auto src = ra.assignmentFor(instr.src1);
+        ASSERT(src.kind == PhysReg::GPR);
+        auto notInt = masm.branchIfNotInt32(src.gpr);
+        // Will be patched to deopt exit
+        (void)notInt;
+        break;
+    }

+    case PMJOp::UnboxInt32: {
+        auto dst = ra.assignmentFor(instr.dst); auto src = ra.assignmentFor(instr.src1);
+        masm.unboxInt32(src.gpr, dst.gpr);
+        break;
+    }

+    case PMJOp::BoxInt32: {
+        auto dst = ra.assignmentFor(instr.dst); auto src = ra.assignmentFor(instr.src1);
+        masm.boxInt32(src.gpr, JSValueRegs(dst.gpr));
+        break;
+    }

+    case PMJOp::GetPropertyDirect: {
+        // Direct property load — no IC, just a pointer offset
+        auto dst  = ra.assignmentFor(instr.dst);
+        auto base = ra.assignmentFor(instr.src1);
+        masm.loadPtr(MacroAssembler::Address(base.gpr, instr.propertyOffset), dst.gpr);
+        break;
+    }

+    case PMJOp::Return: {
+        auto ret = ra.assignmentFor(instr.src1);
+        if (ret.gpr != MacroAssembler::returnValueGPR)
+            masm.move(ret.gpr, MacroAssembler::returnValueGPR);
+        masm.emitFunctionEpilogue();
+        masm.ret();
+        break;
+    }

+    case PMJOp::OSRExit:
+        emitOSRExit(masm, instr.bytecodeOffset);
+        break;

+    default:
+        // Unimplemented op — emit OSR exit
+        emitOSRExit(masm, instr.bytecodeOffset);
+        break;
+    }
+}

+void PMJCompiler::emitOSRExit(MacroAssembler& masm, unsigned bytecodeOffset)
+{
+    // Load the Baseline JIT entry for this bytecodeOffset into PC and jump
+    // The Baseline JIT can resume execution at any bytecode boundary
+    auto* baselineCode = m_codeBlock->baselineJITCode();
+    if (baselineCode) {
+        void* target = baselineCode->executableAddressAtOffset(bytecodeOffset);
+        masm.jump().linkTo(MacroAssembler::AbsoluteAddress(target), &masm);
+    } else {
+        // No Baseline — jump to LLInt entry (slowest case)
+        masm.jump().linkTo(MacroAssembler::AbsoluteAddress(
+            LLInt::getCodePtr<JSEntryPtrTag>(llint_function_for_call_prologue)), &masm);
+    }
+}

+void PMJCompiler::linkDeoptExits(MacroAssembler& masm, Vector<MacroAssembler::Jump>& jumps)
+{
+    // All deopt jumps were collected during emission; link them here
+    for (auto& jump : jumps) {
+        // In a real implementation, each jump has an associated bytecodeOffset
+        // and we link it to the Baseline JIT's OSR entry for that offset.
+        // Simplified: link all to the function's Baseline entry.
+        (void)jump;
+    }
+}

+PMJResult compileFunction(CodeBlock* codeBlock)
+{
+    PMJCompiler compiler(codeBlock);
+    return compiler.compile();
+}

+}} // JSC::PMJ

