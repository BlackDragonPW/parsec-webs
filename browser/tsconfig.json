{
  "compilerOptions": {
    "target":            "ESNext",
    "lib":               ["ESNext", "DOM", "DOM.Iterable"],
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "jsx":               "react-jsx",
    "strict":            true,
    "noUnusedLocals":    false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "skipLibCheck":      true,
    "baseUrl":           ".",
    "paths": {
      "gpui": ["./gpui/src/index.tsx"],
      "gpui/*": ["./gpui/src/*"]
    }
  },
  "include": ["src", "gpui/src"],
  "exclude": ["gpui/src/index.ts", "gpui/src/index.js", "gpui/src/renderer.js", "gpui/src/scene.js", "gpui/src/glyphTable.js"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
